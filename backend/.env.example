PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/clinic-app?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_shared_secret
CLOUDINARY_CLOUD_NAME=replace_with_cloud_name
CLOUDINARY_API_KEY=replace_with_api_key
CLOUDINARY_API_SECRET=replace_with_api_secret

# CRUD works without Cloudinary values, but upload endpoints need all 3 Cloudinary values.
